{
  "browser": {
    "headless": true,
    "noSandbox": true,
    "disableGPU": true,
    "disableDevShmUsage": true,
    "args": [
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--disable-dev-shm-usage",
      "--disable-accelerated-2d-canvas",
      "--disable-gpu",
      "--window-size=1920,1080"
    ]
  }
}
